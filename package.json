{
  "name": "opencode-devspec-plugin",
  "version": "0.2.1",
  "description": "DevSpec integration plugin for OpenCode (opencode.ai) — MCP connection, project conventions, ported commands, autopilot, and remote control.",
  "type": "module",
  "main": "dist/plugin.js",
  "types": "dist/plugin.d.ts",
  "files": [
    "dist",
    "commands",
    "instructions",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
